<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mixtas - E-commerce</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        serif: ['Playfair Display', 'serif'],
                    }
                }
            }
        }

        // Formato automático de 4 en 4 números
        function formatearTarjeta(input) {
            let value = input.value.replace(/\s+/g, '').replace(/[^0-9]/gi, '');
            let matches = value.match(/\d{4,16}/g);
            let match = matches && matches[0] || '';
            let parts = [];

            for (let i = 0, len = match.length; i < len; i += 4) {
                parts.push(match.substring(i, i + 4));
            }

            if (parts.length) {
                input.value = parts.join(' ');
            }
        }

        // Sincronizar inputs con la tarjeta visual
        function actualizarTarjeta() {
            document.getElementById('displayTarjeta').textContent = document.getElementById('inputTarjeta').value || '**** **** **** ****';
            document.getElementById('displayNombre').textContent = document.getElementById('inputNombre').value || 'John Doe';
            document.getElementById('displayFecha').textContent = document.getElementById('inputFecha').value || '00/00';
        }

        // Abrir pasarela de pago
        function abrirPago() {
            cerrarCarrito(); // Ocultamos el carrito antes
            document.getElementById('modalPago').classList.remove('hidden');
        }

        // Cerrar pasarela de pago
        function cerrarPago() {
            document.getElementById('modalPago').classList.add('hidden');
        }

        // Simular el proceso de pago
        function procesarPago(event) {
            event.preventDefault();
            // alert('¡Procesando pago...');
            
            // // Simulación de éxito
            // setTimeout(() => {
            //     alert('¡Pago realizado con éxito!');
            //     localStorage.removeItem('carrito'); // Limpiamos el carrito
            //     location.reload(); // Recargamos para actualizar vista
            // }, 1500);

            // peticion fetch para el pago y luego mostrar un swal de exito
            fetch('/procesarPago', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    //  tomar el usuarios de aqui <input type="text" id="inputNombre" oninput="actualizarTarjeta()" required class="w-full border-b focus:border-black outline-none p-2">
                    usuario: document.getElementById('inputNombre').value,
                    carrito: JSON.parse(localStorage.getItem('carrito'))
                })
            })  
            .then(response => response.json())
            .then(data => {
                if(data.success){
                Swal.fire({
                    icon: 'success',
                    title: '¡Pago realizado con éxito!',
                    showConfirmButton: false,
                    timer: 1500
                }).then(() => {
                    localStorage.removeItem('carrito'); // Limpiamos el carrito
                    location.reload(); // Recargamos para actualizar vista
                })
                }
            })
        }

        // --- Lógica del Carrito ---
        function agregarAlCarrito(id, nombre, precio, imagen) {
            let carrito = JSON.parse(localStorage.getItem('carrito')) || [];
            
            const productoExistente = carrito.find(item => item.id === id);

            if (productoExistente) {
                productoExistente.cantidad += 1;
            } else {
                carrito.push({ id, nombre, precio, imagen, cantidad: 1 });
            }

            localStorage.setItem('carrito', JSON.stringify(carrito));
            actualizarContadorCarrito();
            alert('Producto agregado al carrito');
        }

        function actualizarContadorCarrito() {
            const carrito = JSON.parse(localStorage.getItem('carrito')) || [];
            const total = carrito.reduce((sum, item) => sum + item.cantidad, 0);
            const contadorElemento = document.querySelector('.fa-bag-shopping + span');
            if (contadorElemento) {
                contadorElemento.textContent = total;
            }
        }

        // --- Lógica del Modal ---
        function abrirCarrito() {
            const modal = document.getElementById('modalCarrito');
            const lista = document.getElementById('listaItems');
            const totalDisplay = document.getElementById('totalPrecio');
            const carrito = JSON.parse(localStorage.getItem('carrito')) || [];
            
            lista.innerHTML = '';
            let total = 0;

            carrito.forEach(item => {
                total += (item.precio * item.cantidad);
                lista.innerHTML += `
                    <div class="flex items-center gap-4 py-4 border-b">
                        <img src="${item.imagen}" class="w-16 h-16 object-cover rounded">
                        <div class="flex-1">
                            <h4 class="font-medium text-sm">${item.nombre}</h4>
                            <p class="text-xs text-gray-500">Cantidad: ${item.cantidad}</p>
                            <p class="text-sm font-semibold">$${item.precio}</p>
                        </div>
                    </div>
                `;
            });

            totalDisplay.textContent = `$${total.toFixed(2)}`;
            modal.classList.remove('hidden');
        }

        function cerrarCarrito() {
            document.getElementById('modalCarrito').classList.add('hidden');
        }

        // --- Carga Inicial ---
        window.onload = () => {
            actualizarContadorCarrito();

            fetch('/obtenerProductos')
                .then(response => response.json())
                .then(data => {
                    const productos = document.getElementById('productos');
                    data.forEach(producto => {
                        // Nota: Escapamos comillas simples para evitar errores en onclick
                        const nombreSafe = producto.nombre.replace(/'/g, "\\'");
                        
                        const productoHTML = `
                            <div class="group cursor-pointer">
                                <div class="bg-[#f4f4f4] aspect-square flex items-center justify-center mb-4 overflow-hidden relative">
                                    <img src="${producto.imagen}" alt="${producto.nombre}" class="object-cover w-[80%] mix-blend-multiply group-hover:scale-105 transition duration-500">
                                </div>
                                <div class="text-xs text-gray-400 uppercase tracking-wider mb-1">${producto.nombre}</div>
                                <h3 class="text-sm font-medium text-gray-800 mb-1">${producto.descripcion}</h3>
                                <p class="text-sm text-gray-600">$${producto.precio}</p>
                                <button onclick="agregarAlCarrito('${producto.id}', '${nombreSafe}', ${producto.precio}, '${producto.imagen}')" class="mt-4 bg-black text-white py-2 px-4 rounded-md hover:bg-gray-800 transition duration-300 ease-in-out">
                                    Agregar al Carrito
                                </button>
                            </div>
                        `;
                        productos.innerHTML += productoHTML;
                    });
                })
                .catch(error => console.error('Error:', error));
        }
    </script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:wght@600;700&display=swap');
    </style>
</head>
<body class="font-sans text-gray-800 antialiased bg-white">

    <!-- Header -->
    <div class="relative w-full h-[80vh] md:h-screen bg-cover bg-center bg-blue-300" style="background-image: url('https://images.unsplash.com/photo-1617331713295-1650fdb31180?q=80&w=2070');">
        <header class="absolute top-0 w-full flex items-center justify-between px-6 py-8 text-white z-10">
            <nav class="hidden md:flex gap-6 text-sm font-medium">
                <a href="#" class="hover:text-gray-200">Home</a>
                <a href="/registrar" class="hover:text-gray-200">Registrar Articulos</a>
                <a href="/historial" class="hover:text-gray-200">Ver Historial</a>
            </nav>
            <div class="text-3xl font-serif font-bold tracking-wider">Armando Variedades</div>
            <div class="flex items-center gap-5">
                <button onclick="abrirCarrito()" class="relative">
                    <i class="fa-solid fa-bag-shopping text-xl"></i>
                    <span class="absolute -top-2 -right-2 bg-black text-white text-[10px] rounded-full w-4 h-4 flex items-center justify-center">0</span>
                </button>
            </div>
        </header>
        <!-- ... resto de tu contenido hero ... -->
         <div class="absolute inset-0 flex items-center px-8 md:px-24">
            <button class="absolute left-4 md:left-8 bg-white/80 p-3 rounded-full hover:bg-white text-gray-800 transition">
                <i class="fa-solid fa-chevron-left"></i>
            </button>

            <div class="text-white max-w-lg mt-20">
                <p class="text-xs tracking-[0.2em] font-semibold mb-2 uppercase">Urban Edge</p>
                <h1 class="text-4xl md:text-6xl font-bold leading-tight mb-8">Jackets for the<br>Modern Man</h1>
                <a href="#" class="bg-white text-gray-900 font-medium px-8 py-3 hover:bg-gray-100 transition inline-block">Discovery Now</a>
            </div>

            <button class="absolute right-4 md:right-8 bg-white/80 p-3 rounded-full hover:bg-white text-gray-800 transition">
                <i class="fa-solid fa-chevron-right"></i>
            </button>
        </div>
    </div>

    <!-- Lista de Productos -->
    <section class="max-w-7xl mx-auto px-4 py-20">
        <div class="text-center mb-10"><h2 class="text-3xl md:text-4xl font-medium mb-6">New Arrivals</h2></div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-12" id="productos"></div>
    </section>

    <!-- Modal Carrito -->
    <div id="modalCarrito" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden flex justify-end">
        <div class="bg-white w-full max-w-sm h-full shadow-xl p-6 overflow-y-auto">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-xl font-bold font-serif">Tu Carrito</h2>
                <button onclick="cerrarCarrito()" class="text-2xl hover:text-gray-600">&times;</button>
            </div>
            <div id="listaItems"></div>
            <div class="mt-8 border-t pt-4">
                <div class="flex justify-between font-bold text-lg">
                    <span>Total:</span>
                    <span id="totalPrecio">$0.00</span>
                </div>
                <button onclick="abrirPago()" class="w-full bg-black text-white py-3 mt-4 rounded-md hover:bg-gray-800">
                    Finalizar Compra
                </button>
            </div>
        </div>
    </div>


    <!-- Modal Pasarela de Pago -->
    <div id="modalPago" class="fixed inset-0 bg-black bg-opacity-50 z-[60] hidden flex items-center justify-center p-4">
        <div class="bg-white w-full max-w-2xl rounded-2xl shadow-2xl overflow-hidden flex flex-col md:flex-row">
            <!-- Lado izquierdo: Formulario -->
            <div class="p-8 flex-1">
                <h2 class="text-xl font-bold mb-6">Información de Pago</h2>
                <form id="formPago" onsubmit="procesarPago(event)">
                    <div class="mb-4">
                        <label class="block text-xs uppercase text-gray-400 mb-1">Nombre en la tarjeta</label>
                        <input type="text" id="inputNombre" oninput="actualizarTarjeta()" required class="w-full border-b focus:border-black outline-none p-2">
                    </div>
                    <div class="mb-4">
                        <label class="block text-xs uppercase text-gray-400 mb-1">Número de tarjeta</label>
                        <input type="text" id="inputTarjeta" oninput="formatearTarjeta(this); actualizarTarjeta()" maxlength="19" placeholder="4123 4567 8910 1234" required class="w-full border-b focus:border-black outline-none p-2">
                    </div>
                    <div class="flex gap-4 mb-6">
                        <div class="w-1/2">
                            <label class="block text-xs uppercase text-gray-400 mb-1">Expira</label>
                            <input type="text" id="inputFecha" oninput="actualizarTarjeta()" placeholder="MM/AA" maxlength="5" required class="w-full border-b focus:border-black outline-none p-2">
                        </div>
                        <div class="w-1/2">
                            <label class="block text-xs uppercase text-gray-400 mb-1">CVV</label>
                            <input type="password" maxlength="3" required class="w-full border-b focus:border-black outline-none p-2">
                        </div>
                    </div>
                    <button type="submit" class="w-full bg-red-500 text-white py-3 rounded-full font-bold hover:bg-red-600">Completar el Pago</button>
                </form>
            </div>

            <!-- Lado derecho: Visualización de tarjeta (Simulación de image_64d683.png) -->
            <div class="bg-indigo-600 p-8 flex flex-col justify-between text-white w-full md:w-64">
                <div class="w-10 h-8 bg-yellow-200 rounded opacity-80 mb-8"></div>
                <div>
                    <p id="displayTarjeta" class="text-lg tracking-widest font-mono">**** **** **** ****</p>
                    <div class="flex justify-between mt-6 text-xs uppercase opacity-80">
                        <span id="displayNombre">John Doe</span>
                        <span id="displayFecha">00/00</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

</body>
</html>